    "vue-i18n": "^11.3.0"
  },
  "devDependencies": {
    "@dg-scripts/eslint-config": "^6.1.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-plugin-format": "^2.0.1",
    "jsdom": "^29.0.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^8.0.1",
