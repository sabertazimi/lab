{
  "name": "@lab/mortal-ui",
  "type": "module",
  "version": "3.2.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test": "vitest run --coverage",
