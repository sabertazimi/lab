{
  "name": "@lab/vue-trello",
  "type": "module",
  "version": "3.3.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "vue-tsc --noEmit && vite build",
    "dev": "vite",
    "lint": "pnpm lint:style && pnpm lint:type-check",
    "lint:style": "eslint ./src && stylelint ./src/**/*.{css,vue}",
    "lint:type-check": "vue-tsc --noEmit",
    "lint:fix": "eslint --fix ./src && stylelint ./src/**/*.{css,vue} --fix",
    "serve": "vite preview"
  },
  "dependencies": {
    "nanoid": "^5.1.11",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@dg-scripts/eslint-config": "^6.2.0",
    "@dg-scripts/stylelint-config": "^6.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.12.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vue-tsc": "^3.3.1"
  }
}
