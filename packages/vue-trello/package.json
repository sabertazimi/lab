{
  "name": "@lab/vue-trello",
  "version": "3.2.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "vue-tsc --noEmit && vite build",
    "dev": "vite",
    "lint": "pnpm lint:style && pnpm lint:type-check",
    "lint:style": "eslint ./src && stylelint ./src/**/*.{css,vue}",
    "lint:type-check": "vue-tsc --noEmit",
    "lint:fix": "eslint --fix ./src && stylelint ./src/**/*.{css,vue} --fix",
    "serve": "vite preview"
  },
  "dependencies": {
    "nanoid": "^5.1.7",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@dg-scripts/eslint-config": "^6.1.1",
    "@dg-scripts/stylelint-config": "^6.1.1",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.3",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "stylelint": "^17.5.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vue-tsc": "^3.2.6"
  }
}
