{
  "name": "@lab/m-league-reviewer",
  "type": "module",
  "version": "3.4.0",
  "private": true,
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "lint": "eslint . && pnpm lint:typecheck",
    "lint:typecheck": "react-router typegen && tsc",
    "lint:fix": "eslint . --fix",
    "format": "git diff --name-only --cached --relative | grep -E \"\\.(ts|tsx|js|jsx)$\" | xargs -r prettier --write && git diff --name-only --cached --relative | grep -E \"\\.(ts|tsx|js|jsx)$\" | xargs -r eslint --fix",
    "test": "vitest run --coverage",
    "fetch:game": "node scripts/fetch.ts && node scripts/fix.ts",
    "fetch:schedule": "node scripts/fetch-game-schedule.ts"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-router/node": "^7.15.1",
    "@react-router/serve": "^7.15.1",
    "@tiptap/extensions": "^3.23.5",
    "@tiptap/pm": "^3.23.5",
    "@tiptap/react": "^3.23.5",
    "@tiptap/starter-kit": "^3.23.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.2.1",
    "dompurify": "^3.4.5",
    "isbot": "^5.1.40",
    "lucide-react": "^1.16.0",
    "motion": "^12.39.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@dg-scripts/eslint-config": "^6.2.0",
